export const deepseekWebMiddleware = (executor: DeepSeekWebExecutor) => {
  return async (req, res) => {
    // 1. Translate OpenAI format → DeepSeek
    // 2. Execute request
    // 3. Stream response to client
    // 4. Handle errors with proper codes
  }
}
```

